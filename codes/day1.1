public class TypePromotionExample {
    public static void main(String[] args) {
        int a = 5;
        char b = 'A';  // ASCII value of 'A' is 65
        double c = 2.5;

        // Expression involving mixed data types
        double result = a + b * c;

        System.out.println("Result of (a + b * c) = " + result);
    }
}

